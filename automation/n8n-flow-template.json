{
  "name": "STEC CRM Batch Normalize",
  "nodes": [
    {
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [200, 240],
      "parameters": {
        "path": "stec-inscritos",
        "httpMethod": "POST",
        "responseMode": "lastNode"
      }
    },
    {
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [430, 240],
      "parameters": {
        "batchSize": 50
      }
    },
    {
      "name": "HTTP Worker",
      "type": "n8n-nodes-base.httpRequest",
      "position": [680, 240],
      "parameters": {
        "method": "POST",
        "url": "http://YOUR_DROPLET_IP:8080/transform",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"oportunidad\": $json.oportunidad, \"records\": $json.records}"
      }
    },
    {
      "name": "Aggregate",
      "type": "n8n-nodes-base.code",
      "position": [930, 240],
      "parameters": {
        "jsCode": "const allRows = [];\nconst allErrors = [];\nfor (const item of items) {\n  const payload = item.json;\n  if (payload.rows) allRows.push(...payload.rows);\n  if (payload.errors) allErrors.push(...payload.errors);\n}\nreturn [{ json: { totalRows: allRows.length, rows: allRows, errors: allErrors } }];"
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "Split In Batches", "type": "main", "index": 0 }]]
    },
    "Split In Batches": {
      "main": [[{ "node": "HTTP Worker", "type": "main", "index": 0 }]]
    },
    "HTTP Worker": {
      "main": [[{ "node": "Aggregate", "type": "main", "index": 0 }]]
    }
  }
}
